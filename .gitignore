# Arquivos de ambiente
.env

# Ignorar conteúdo das pastas, mas manter a estrutura (via .gitkeep)
build/*
!build/.gitkeep
logs/*
!logs/.gitkeep
sql/*
!sql/.gitkeep
template/*
!template/.gitkeep

# Arquivos de dados com credenciais (nunca versionar)
data/user_dashboards.xlsx
data/Cadastro*.xlsx

# Arquivos gerados pelo Python
__pycache__/